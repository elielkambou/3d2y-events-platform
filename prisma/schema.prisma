generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  AGENCY
  AGENCY_SCANNER
  SUPPORT_AGENT
  CONTENT_ADMIN
  FINANCE_ADMIN
  SUPER_ADMIN
}

enum AgencyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum EventStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
  CANCELLED
}

enum OccurrenceStatus {
  DRAFT
  PUBLISHED
  SOLD_OUT
  CANCELLED
  COMPLETED
}

enum TicketTypeStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SOLD_OUT
}

enum OrderStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
  EXPIRED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  MOBILE_MONEY
  CARD
  CASH
  OTHER
}

enum TicketStatus {
  RESERVED
  ISSUED
  CHECKED_IN
  CANCELLED
  TRANSFERRED
  REFUNDED
  EXPIRED
}

enum CheckInResult {
  SUCCESS
  ALREADY_USED
  INVALID
  CANCELLED
  REFUNDED
  EXPIRED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceType {
  PHYSICAL_TICKET_SALES
  TICKET_PRINTING
  SMS_PROMOTION
  EMAIL_PROMOTION
  CREATIVE_DESIGN
}

enum ServiceOrderStatus {
  PENDING
  QUOTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  fullName        String?
  phone           String?
  avatarUrl       String?
  passwordHash    String?
  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  roles           UserRoleAssignment[]
  agency          Agency?
  customerOrders  Order[]
  scannedCheckIns TicketCheckIn[]
  refundRequests  RefundRequest[]      @relation("RefundRequestedBy")
  reviewedRefunds RefundRequest[]      @relation("RefundReviewedBy")
  eventApprovals  EventApproval[]      @relation("EventApprovedBy")
  sessions        AuthSession[]
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      UserRole
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
}

model Agency {
  id                String       @id @default(cuid())
  ownerUserId       String       @unique
  name              String
  slug              String       @unique
  email             String
  phone             String?
  description       String?
  logoUrl           String?
  coverImageUrl     String?
  status            AgencyStatus @default(PENDING)
  commissionRateBps Int          @default(1000)
  isVerified        Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  owner             User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  events            Event[]
  orders            Order[]
  commissionEntries CommissionLedger[]
  serviceOrders     AgencyServiceOrder[]

  @@index([status])
  @@index([slug])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())

  events Event[]
}

model Venue {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  addressLine   String?
  municipality  String?
  district      String?
  city          String   @default("Abidjan")
  country       String   @default("Côte d'Ivoire")
  latitude      Decimal? @db.Decimal(10, 7)
  longitude     Decimal? @db.Decimal(10, 7)
  googlePlaceId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  occurrences EventOccurrence[]

  @@index([city])
  @@index([district])
  @@index([googlePlaceId])
}

model Event {
  id                 String      @id @default(cuid())
  agencyId           String
  categoryId         String?
  title              String
  slug               String      @unique
  shortDescription   String?
  fullDescription    String?
  coverImageUrl      String?
  status             EventStatus @default(DRAFT)
  isFeatured         Boolean     @default(false)
  isPublished        Boolean     @default(false)
  defaultCurrency    String      @default("XOF")
  termsAndConditions String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  publishedAt        DateTime?

  agency        Agency               @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  category      Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  occurrences   EventOccurrence[]
  mediaAssets   EventMedia[]
  approvals     EventApproval[]
  serviceOrders AgencyServiceOrder[]

  @@index([agencyId])
  @@index([categoryId])
  @@index([status])
  @@index([isPublished])
  @@index([publishedAt])
}

model EventMedia {
  id        String   @id @default(cuid())
  eventId   String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventOccurrence {
  id               String           @id @default(cuid())
  eventId          String
  venueId          String
  title            String?
  startsAt         DateTime
  endsAt           DateTime
  salesStartAt     DateTime?
  salesEndAt       DateTime?
  reservationEndAt DateTime?
  timezone         String           @default("Africa/Abidjan")
  capacity         Int?
  status           OccurrenceStatus @default(DRAFT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  venue       Venue        @relation(fields: [venueId], references: [id], onDelete: Restrict)
  ticketTypes TicketType[]
  orderItems  OrderItem[]
  tickets     Ticket[]

  @@index([eventId])
  @@index([venueId])
  @@index([startsAt])
  @@index([status])
}

model ReservationPolicy {
  id               String   @id @default(cuid())
  ticketTypeId     String   @unique
  isEnabled        Boolean  @default(false)
  depositPercent   Decimal? @db.Decimal(5, 2)
  gracePeriodHours Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
}

model TicketType {
  id           String           @id @default(cuid())
  occurrenceId String
  name         String
  description  String?
  priceAmount  Decimal          @db.Decimal(12, 2)
  currency     String           @default("XOF")
  totalStock   Int
  maxPerOrder  Int?
  isReservable Boolean          @default(false)
  saleStartsAt DateTime?
  saleEndsAt   DateTime?
  status       TicketTypeStatus @default(DRAFT)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  occurrence        EventOccurrence    @relation(fields: [occurrenceId], references: [id], onDelete: Cascade)
  reservationPolicy ReservationPolicy?
  orderItems        OrderItem[]
  tickets           Ticket[]

  @@index([occurrenceId])
  @@index([status])
}

model Order {
  id               String      @id @default(cuid())
  userId           String?
  agencyId         String
  customerEmail    String
  customerName     String?
  customerPhone    String?
  status           OrderStatus @default(PENDING)
  subtotalAmount   Decimal     @db.Decimal(12, 2)
  feesAmount       Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount   Decimal     @default(0) @db.Decimal(12, 2)
  commissionAmount Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal     @db.Decimal(12, 2)
  currency         String      @default("XOF")
  source           String      @default("web")
  expiresAt        DateTime?
  paidAt           DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  agency            Agency             @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  items             OrderItem[]
  payments          Payment[]
  commissionEntries CommissionLedger[]
  refundRequests    RefundRequest[]

  @@index([userId])
  @@index([agencyId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  ticketTypeId String
  occurrenceId String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  lineTotal    Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType      @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  occurrence EventOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Restrict)
  tickets    Ticket[]

  @@index([orderId])
  @@index([ticketTypeId])
  @@index([occurrenceId])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerReference String?       @unique
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod @default(OTHER)
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("XOF")
  paidAt            DateTime?
  rawPayload        Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([provider])
}

model Ticket {
  id           String       @id @default(cuid())
  orderItemId  String
  ticketTypeId String
  occurrenceId String
  holderName   String?
  holderEmail  String?
  serialNumber String       @unique
  qrTokenHash  String       @unique
  status       TicketStatus @default(RESERVED)
  issuedAt     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orderItem      OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  ticketType     TicketType      @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  occurrence     EventOccurrence @relation(fields: [occurrenceId], references: [id], onDelete: Restrict)
  checkIns       TicketCheckIn[]
  refundRequests RefundRequest[]

  @@index([orderItemId])
  @@index([ticketTypeId])
  @@index([occurrenceId])
  @@index([status])
}

model TicketCheckIn {
  id                 String        @id @default(cuid())
  ticketId           String
  checkedInByUserId  String?
  checkedInAt        DateTime      @default(now())
  scannerDeviceLabel String?
  result             CheckInResult
  notes              String?

  ticket      Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  checkedInBy User?  @relation(fields: [checkedInByUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([checkedInByUserId])
  @@index([checkedInAt])
}

model RefundRequest {
  id                String       @id @default(cuid())
  orderId           String?
  ticketId          String?
  requestedByUserId String?
  reviewedByUserId  String?
  reason            String?
  status            RefundStatus @default(REQUESTED)
  requestedAmount   Decimal?     @db.Decimal(12, 2)
  approvedAmount    Decimal?     @db.Decimal(12, 2)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  processedAt       DateTime?

  order       Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  ticket      Ticket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  requestedBy User?   @relation("RefundRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  reviewedBy  User?   @relation("RefundReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([ticketId])
  @@index([status])
}

model EventApproval {
  id               String         @id @default(cuid())
  eventId          String
  reviewedByUserId String?
  status           ApprovalStatus @default(PENDING)
  comment          String?
  createdAt        DateTime       @default(now())

  event      Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("EventApprovedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([status])
}

model CommissionLedger {
  id               String   @id @default(cuid())
  agencyId         String
  orderId          String
  grossAmount      Decimal  @db.Decimal(12, 2)
  commissionAmount Decimal  @db.Decimal(12, 2)
  netAmount        Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([orderId])
}

model AgencyServiceOrder {
  id          String             @id @default(cuid())
  agencyId    String
  eventId     String?
  serviceType ServiceType
  quantity    Int                @default(1)
  unitPrice   Decimal            @db.Decimal(12, 2)
  totalPrice  Decimal            @db.Decimal(12, 2)
  status      ServiceOrderStatus @default(PENDING)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  event  Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([agencyId])
  @@index([eventId])
  @@index([serviceType])
  @@index([status])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
